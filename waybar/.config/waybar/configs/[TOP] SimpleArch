{
  "position": "top",
  "margin-top": 0,
  "modules-left": [
    "custom/launcher",
    "custom/cava",
    "custom/currently-playing"
  ],
  "modules-center": [
    "hyprland/workspaces",
    "clock",
    "custom/weather"
  ],
  "modules-right": [
    "tray",
    "custom/clipboard",
    "group/nm",
    "group/controls",
    "group/system-stats",
    "group/notif",
    "group/power"
  ],
  "group/nm": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-network",
      "transition-left-to-right": false
    },
    "modules": [
      "network",
      "bluetooth"
    ]
  },
  "custom/launcher": {
    "format": "¾░Żć",
    "tooltip": false,
    "on-click": "rofi -show drun -modi drun,filebrowser,run,window -theme ~/.config/rofi/launcher-full.rasi"
  },
  "custom/nvidia": {
    "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,nounits,noheader | sed 's/\\([0-9]\\+\\), \\([0-9]\\+\\)/’äø \\1% | \\2┬░C/g'",
    "format": "{} ’ŗē",
    "interval": 2
  },
  "group/system-stats": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-battery",
      "transition-left-to-right": false
    },
    "modules": [
      "battery",
      "cpu",
      "memory",
      "disk",
      "temperature",
      "custom/nvidia"
    ]
  },
  "group/notif": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-custom/notification",
      "transition-left-to-right": false
    },
    "modules": [
    "custom/notification",
    "systemd-failed-units",
    "privacy",
    "custom/kdeconnect"
    ]
  },
  "group/power": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-custom/power",
      "transition-left-to-right": false
    },
    "modules": [
    "custom/power",
    "idle_inhibitor",
    "custom/logout",
    "custom/reboot",
    "custom/lock"
    ]
  },
  "group/controls": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-custom/pulseaudio",
      "transition-left-to-right": false
    },
    "modules": [
    "pulseaudio",
    "custom/color-picker",
    "custom/nightmode",
    "backlight"
    ]
  },
  "custom/color-picker": {
    "on-click": "hyprpicker --autocopy",
    "format": "’ć╗",
    "tooltip": false
  },
  "cpu": {
      "interval": 1,
      "format": "{usage}% ’ŗø",
      "on-click":"kitty -e btop",
      "max-length": 10
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "tooltip": false,
    "tooltip-format": "{percent}%",
    "format-icons": ["’äæ", "¾░āø", "¾░ā£", "¾░āØ", "¾░ā×", "¾░ā¤", "¾░āĀ"]
  },
  "custom/power": {
  	"format": "ŌÅ╗",
  	"tooltip-format": "Power Menu",
  	"on-click": "~/.local/bin/powermenu.sh",
	"tooltip": false
  },
  "clock": {
    "format": "{:%a, %b %d %Y | %H:%M}",
    "on-click":"flatpak run com.super_productivity.SuperProductivity",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode"          : "month",
      "mode-mon-col"  : 3,
      "weeks-pos"     : "right",
      "on-scroll"     : 1
      },
    "actions":  {
                "on-click-right": "mode",
                "on-scroll-up": "shift_up",
                "on-scroll-down": "shift_down"
                }
    },
  "custom/weather": {
    "exec": "~/.config/waybar/scripts/openmeteo.sh",
    "return-type": "json",
    "interval": 1800,
    "on-click": "flatpak run io.github.amit9838.mousam",
    "format": "{text}"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "¾░║Ģ",
      "2": "’äī",
      "3": "’äī",
      "4": "’äī",
      "5": "’äī",
      "active": "’åÆ",
      "default": "’äī"
    },
    "on-scroll-up": "hyprctl dispatch 'hl.dsp.focus({ workspace = \"m-1\" })' > /dev/null",
    "on-scroll-down":"hyprctl dispatch 'hl.dsp.focus({ workspace = \"m+1\" })' > /dev/null",
    "persistent-workspaces": {
      "*": 5,
      "HDMI-A-1": 3
    }
  },
  "custom/cava": {
    "exec": "~/.config/waybar/scripts/cava.sh",
    "format": "{}",
    "restart-interval": 1,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": false
  },
  "custom/currently-playing": {
    "exec": "/home/harsh/.config/waybar/scripts/currently-playing.sh",
    "format": "{alt} {text}",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10,
    "icons": {
    }
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}¾░é░",
    "format-muted": "¾░Ø¤",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’Ćź",
      "headset": "’Ćź",
      "phone": "’éĢ",
      "phone-muted": "Ņ┤Ś",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": [
        "’Ć¦",
        "’Ć©"
      ]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": [
      "Easy Effects Sink"
    ]
  },
  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "{essid} ¾░¢®",
    "format-ethernet": "{ipaddr}/{cidr} ŅĮä",
    "format-disconnected": "¾░¢¬",
    "tooltip-format": "’āü {ifname} via {gwaddri}",
    "tooltip-format-wifi": "¾░¢® {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "’āü {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "iwgtk"
  },
  "bluetooth": {
    "format": "{status} ¾░é»",
    "format-disconnected": "¾░é▓",
    "format-connected": "{device_alias} ¾░é»",
    "format-connected-battery": "{device_alias} {device_battery_percentage}% ¾░é»",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "overskride"
  },
  "battery": {
    "interval": 60,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "tooltip": true,
    "format-icons": [
      "¾░ü║",
      "¾░ü╗",
      "¾░ü╝",
      "¾░üĮ",
      "¾░üŠ",
      "¾░ü┐",
      "¾░éĆ",
      "¾░éü",
      "¾░éé",
      "¾░ü╣"
    ],
    "max-length": 25
  },
  "custom/notification": {
    "tooltip": true,
    "format": "<span size='10pt'>{icon}</span>",
    "format-icons": {
      "notification": "¾▒ģ½",
      "none": "¾░é£",
      "dnd-notification": "¾░éĀ",
      "dnd-none": "¾░¬ō",
      "inhibited-notification": "¾░éø",
      "inhibited-none": "¾░¬æ",
      "dnd-inhibited-notification": "¾░éø",
      "dnd-inhibited-none": "¾░¬æ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "disk": {
	"interval": 30,
	"format": "{percentage_free}% ’ćĆ"
},
  "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
          "activated": "’ü«",
          "deactivated": "’ü░"
      }
  },
  "memory": {
    "interval": 1,
    "format": "{}% Ņ┐ģ",
    "max-length": 10
  },
  "privacy": {
    "icon-spacing": 2,
    "icon-size": 18,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 18
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 18
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 18
      }
    ],
    "ignore-monitor": true,
    "ignore": [
      {
        "type": "audio-in",
        "name": "cava"
      },
      {
        "type": "screenshare",
        "name": "obs"
      }
    ]
  },
  "systemd-failed-units": {
    "hide-on-ok": true,
    "format": "Ō£Ś {nr_failed}",
    "format-ok": "Ō£ō",
    "system": true,
    "user": false
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C ’ŗć",
    "format": "{temperatureC}┬░C ’ŗē"
  },
  "custom/lock": {
    "format": "’ĆŻ",
    "tooltip-format": "Lock",
    "on-click": "hyprlock 2>/dev/null"
  },
  "custom/logout": {
    "format": "¾░Źā",
    "tooltip-format": "Logout",
    "on-click": "hyprshutdown"
  },
  "custom/reboot": {
    "format": "¾░£ē",
    "tooltip-format": "Reboot",
    "on-click": "hyprshutdown -t 'Restarting...' --post-cmd 'reboot'"
  },
  "custom/clipboard": {
    "format": "ŅĄ╗",
    "on-click": "nwg-clipman",
    "tooltip": false
  },
  "custom/kdeconnect": {
    "exec": "~/.config/waybar/scripts/kdeconnect.sh",
    "interval": 300,
    "format": "’äŗ",
    "on-click": "kdeconnect-app",
    "tooltip": false
  },
  "custom/nightmode": {
    "exec": "pgrep -x hyprsunset >/dev/null && echo '¾░¢”' || echo '¾░¢©'",
    "interval": 5,
